# Copie para `.env` antes de rodar `docker compose up`.
# `.env` esta no .gitignore — nunca comite credenciais reais.

# Banco PostgreSQL
POSTGRES_DB=goodfunds
POSTGRES_USER=goodfunds
POSTGRES_PASSWORD=goodfunds
POSTGRES_PORT=5432

# Backend
APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Origens autorizadas a consumir a API via browser (CORS), separadas por virgula.
# Default cobre o dev server do Vite (:5173) e o frontend do compose (:3000).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT secret usado pelo perfil prod (obrigatorio).
# Gere um valor longo e aleatorio, por exemplo:
#   openssl rand -base64 48
JWT_SECRET=change-me-please-change-me-please-change-me-please

# Diretorio (no container/host) onde os PDFs de fatura sao salvos.
# Default: ./uploads (relativo ao working dir do app).
APP_UPLOADS_DIR=./uploads

# Frontend (servido por nginx no compose)
FRONTEND_PORT=3000
# URL que o frontend (rodando no browser) usa para chamar a API.
# Como o backend e exposto no host em APP_PORT, mantenha localhost aqui.
VITE_API_BASE_URL=http://localhost:8080
